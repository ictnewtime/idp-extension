{
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "useTabs": false,
    "printWidth": 120,
    "trailingComma": "es5",
    "plugins": ["@prettier/plugin-php"],
    "overrides": [
        {
            "files": "*.php",
            "options": {
                "parser": "php",
                "phpVersion": "8.2",
                "singleQuote": false,
                "tabWidth": 4,
                "braceStyle": "psr-2"
            }
        }
    ]
}
